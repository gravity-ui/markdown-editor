{
  "name": "@markdown-editor/docs-gen",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "nx": {
    "name": "@markdown-editor/infra/docs-gen",
    "targets": {
      "build": {
        "outputs": [
          "{workspaceRoot}/dist/docs"
        ]
      }
    }
  },
  "scripts": {
    "build": "node src/generate-docs.mjs && yfm -i ../../tmp/docs-src -o ../../dist/docs"
  },
  "dependencies": {
    "@diplodoc/cli": "5.50.3"
  }
}
